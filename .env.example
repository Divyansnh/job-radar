# Copy to .env and fill in your details

# Gmail (create App Password at https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Your profile
YOUR_NAME=Your Full Name
YOUR_EMAIL=your.email@gmail.com
GITHUB_URL=https://github.com/yourusername
PROJECT_GITHUB_URL=https://github.com/Divyansnh/expiry_tracker_final
DEMO_VIDEO_URL=https://www.youtube.com/watch?v=Dge_LY-7zbg
LOOM_URL=https://www.loom.com/share/your-followup-loom
LINKEDIN_URL=https://www.linkedin.com/in/yourprofile

# Optional: Hunter.io for better email finding (free tier: ~25 searches/month)
# Sign up: https://hunter.io/users/sign_up — API key: https://hunter.io/api-keys
HUNTER_API_KEY=your_hunter_api_key
